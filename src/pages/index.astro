  <!-- Hero -->
  <section class="relative flex items-center" style="background-color:var(--color-brand-accent);min-height:88vh">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full opacity-20" style="background:radial-gradient(circle,#4040FF,transparent 70%);transform:translate(30%,-20%)"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 rounded-full opacity-10" style="background:radial-gradient(circle,#ffffff,transparent 70%);transform:translate(-30%,30%)"></div>
    </div>
    <div class="max-w-6xl mx-auto px-4 py-24 relative z-10 w-full">
      <span class="inline-flex items-center gap-2 bg-white/15 text-white/90 px-4 py-1.5 rounded-full text-sm mb-6">📍 Cranleigh, Ewhurst &amp; Bramley, Surrey</span>
      <h1 class="text-5xl md:text-6xl text-white mb-6 max-w-2xl leading-tight">
        Dog walking<br />your <span class="text-blue-200">four-legged</span><br />friend will love
      </h1>
      <p class="text-white/80 text-lg max-w-xl mb-8 leading-relaxed">
        We are a family duo, Art and Mandy, offering a warm and personal service in the Cranleigh, Ewhurst and Bramley areas. Over five years walking the beautiful Surrey Hills.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/P3473/contact" class="bg-white text-[var(--color-brand-accent)] px-8 py-3 rounded-full font-bold hover:bg-blue-50 transition-colors">Book a Walk</a>
        <a href="/P3473/services" class="bg-white/15 text-white px-8 py-3 rounded-full font-semibold hover:bg-white/25 transition-colors border border-white/30">Our Services</a>
      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <section class="bg-[var(--color-brand-accent-deep)] py-5">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-wrap justify-center gap-x-10 gap-y-3">
        <div class="flex items-center gap-2 text-white/80 text-sm">
          <span class="text-blue-200">🛡️</span>
          <span>Fully insured including key cover</span>
        </div>
        <div class="flex items-center gap-2 text-white/80 text-sm">
          <span class="text-blue-200">🎓</span>
          <span>PIF qualified for canine care</span>
        </div>
        <div class="flex items-center gap-2 text-white/80 text-sm">
          <span class="text-blue-200">⏱️</span>
          <span>Over 5 years experience</span>
        </div>
        <div class="flex items-center gap-2 text-white/80 text-sm">
          <span class="text-blue-200">🚐</span>
          <span>Comfortable, customised van</span>
        </div>
        <div class="flex items-center gap-2 text-white/80 text-sm">
          <span class="text-blue-200">👨‍👩‍👧</span>
          <span>Small family team of two</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-20 bg-[var(--color-brand-bg)]">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl text-[var(--color-ink)] mb-3">What We Offer</h2>
        <p class="text-[var(--color-ink-soft)] max-w-xl mx-auto">Tailored services for every dog and every lifestyle, from hourly group walks to overnight house sitting.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Dog Walks -->
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-[var(--color-border)] hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-[var(--color-accent-light)] flex items-center justify-center text-2xl mb-4">🐕</div>
          <h3 class="text-xl font-display font-extrabold text-[var(--color-ink)] mb-2">Dog Walks</h3>
          <p class="text-[var(--color-ink-soft)] text-sm leading-relaxed mb-3">1-hour group walks in the Surrey Hills. Socialising, recall training and plenty of fun. Dogs are collected and dropped home.</p>
          <div class="text-[var(--color-brand-accent)] font-bold text-lg">£15 per dog</div>
        </div>
        <!-- Hikes -->
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-[var(--color-border)] hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-[var(--color-accent-light)] flex items-center justify-center text-2xl mb-4">🥾</div>
          <h3 class="text-xl font-display font-extrabold text-[var(--color-ink)] mb-2">Hikes</h3>
          <p class="text-[var(--color-ink-soft)] text-sm leading-relaxed mb-3">3-hour hikes on Friday afternoons for those dogs with extra energy. The perfect end to the working week.</p>
          <div class="text-[var(--color-brand-accent)] font-bold text-lg">£30 per dog</div>
        </div>
        <!-- Puppy Visits -->
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-[var(--color-border)] hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-[var(--color-accent-light)] flex items-center justify-center text-2xl mb-4">🐾</div>
          <h3 class="text-xl font-display font-extrabold text-[var(--color-ink)] mb-2">Puppy Visits</h3>
          <p class="text-[var(--color-ink-soft)] text-sm leading-relaxed mb-3">We pop in to give your puppy a little company whilst you are out and about. Short, friendly 20-minute visits.</p>
          <div class="text-[var(--color-brand-accent)] font-bold text-lg">£8 per 20 min</div>
        </div>
        <!-- House Sitting -->
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-[var(--color-border)] hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-[var(--color-accent-light)] flex items-center justify-center text-2xl mb-4">🏠</div>
          <h3 class="text-xl font-display font-extrabold text-[var(--color-ink)] mb-2">House Sitting</h3>
          <p class="text-[var(--color-ink-soft)] text-sm leading-relaxed mb-3">Peace of mind while you are away. Your dogs are cared for at home by someone they already know and trust.</p>
          <div class="text-[var(--color-brand-accent)] font-bold text-lg">From £40/night</div>
        </div>
      </div>
      <div class="text-center mt-10">
        <a href="/P3473/services" class="inline-block border-2 border-[var(--color-brand-accent)] text-[var(--color-brand-accent)] px-8 py-3 rounded-full font-bold hover:bg-[var(--color-brand-accent)] hover:text-white transition-colors">View Full Services &amp; Prices</a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-4xl text-[var(--color-ink)] mb-5">About Us</h2>
          <p class="text-[var(--color-ink-soft)] leading-relaxed mb-4">
            Welcome to Howl at the Moon dog walking. We are a family duo, Art and Mandy, offering a warm and personal service in the Cranleigh, Ewhurst and Bramley areas.
          </p>
          <p class="text-[var(--color-ink-soft)] leading-relaxed mb-4">
            We have been walking the beautiful Surrey Hills all our lives and know all the best trails. Whether it is rootling in the woods or running through open grasslands, every route is safe and far from roads. Whatever the weather, we do our best to operate.
          </p>
          <p class="text-[var(--color-ink-soft)] leading-relaxed mb-6">
            We walk in a group of dogs so it is an excellent opportunity for socialising, and many of our regulars have become good tail-wagging friends. We pick up and drop off to home in a comfortable, customised van and can arrange keys if you are not home.
          </p>
          <div class="flex flex-col gap-3">
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-brand-accent)] mt-0.5 font-bold">✓</span>
              <span class="text-[var(--color-ink-soft)] text-sm">Passionate walkers who have lived in the area for 20 years</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-brand-accent)] mt-0.5 font-bold">✓</span>
              <span class="text-[var(--color-ink-soft)] text-sm">Small family team so your dog will always know who is walking them</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-brand-accent)] mt-0.5 font-bold">✓</span>
              <span class="text-[var(--color-ink-soft)] text-sm">All group walks include recall training and socialisation</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-brand-accent)] mt-0.5 font-bold">✓</span>
              <span class="text-[var(--color-ink-soft)] text-sm">Over five years of rewarding experience with dogs and their families</span>
            </div>
          </div>
          <a href="/P3473/contact" class="mt-8 inline-block bg-[var(--color-brand-accent)] text-white px-8 py-3 rounded-full font-bold hover:bg-[var(--color-brand-accent-deep)] transition-colors">Get in Touch</a>
        </div>
        <div class="relative">
          <div class="rounded-2xl overflow-hidden shadow-lg">
            <img src="/P3473/images/art-20with-20dogs.jpg" alt="Art with dogs on a walk in Surrey" width="978" height="607" loading="lazy" class="w-full object-cover" />
          </div>
          <div class="absolute -bottom-4 -left-4 bg-[var(--color-brand-accent)] text-white rounded-xl px-5 py-3 shadow-lg">
            <div class="font-display font-extrabold text-2xl">5+</div>
            <div class="text-blue-200 text-xs">Years experience</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-20 bg-[var(--color-cream)]">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div class="grid grid-cols-2 gap-3">
          <div class="aspect-square overflow-hidden rounded-xl">
            <img src="/P3473/images/imag0016.jpeg" alt="Dog on a walk" width="204" height="196" loading="lazy" class="w-full h-full object-cover" />
          </div>
          <div class="aspect-square overflow-hidden rounded-xl">
            <img src="/P3473/images/imag0389.jpg" alt="Dogs on a walk in Surrey" width="204" height="196" loading="lazy" class="w-full h-full object-cover" />
          </div>
          <div class="aspect-square overflow-hidden rounded-xl">
            <img src="/P3473/images/imag0558.jpg" alt="Group dog walk" width="204" height="196" loading="lazy" class="w-full h-full object-cover" />
          </div>
          <div class="aspect-square overflow-hidden rounded-xl">
            <img src="/P3473/images/imag0604.jpg" alt="Happy dog" width="204" height="196" loading="lazy" class="w-full h-full object-cover" />
          </div>
        </div>
        <div>
          <h2 class="text-4xl text-[var(--color-ink)] mb-6">Why Choose Howl at the Moon?</h2>
          <ul class="flex flex-col gap-4">
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[var(--color-brand-accent)] text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">✓</span>
              <span class="text-[var(--color-ink-soft)] text-sm">Whatever the weather, we do our best to operate</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[var(--color-brand-accent)] text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">✓</span>
              <span class="text-[var(--color-ink-soft)] text-sm">Walks predominantly in the beautiful Surrey Hills</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[var(--color-brand-accent)] text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">✓</span>
              <span class="text-[var(--color-ink-soft)] text-sm">Woodland walks far from roads with plenty of space for dogs to be dogs</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[var(--color-brand-accent)] text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">✓</span>
              <span class="text-[var(--color-ink-soft)] text-sm">Insured from the moment we pick them up to the moment we drop them home, including key cover</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[var(--color-brand-accent)] text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">✓</span>
              <span class="text-[var(--color-ink-soft)] text-sm">Qualified through PIF for canine care</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[var(--color-brand-accent)] text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">✓</span>
              <span class="text-[var(--color-ink-soft)] text-sm">Group walks offer recall training, socialisation and treats for mental and physical stimulation</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial Teaser -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="text-4xl text-[var(--color-ink)] mb-3">What Our Clients Say</h2>
        <p class="text-[var(--color-ink-soft)]">Dogs and their owners love Howl at the Moon.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-[var(--color-brand-bg)] rounded-2xl p-6 border border-[var(--color-border)]">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-full overflow-hidden flex-shrink-0">
              <img src="/P3473/images/treacle.jpeg" alt="Treacle the Basset Hound" width="48" height="48" loading="lazy" class="w-full h-full object-cover" />
