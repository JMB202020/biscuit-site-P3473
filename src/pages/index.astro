          <ul class="flex flex-col gap-2 text-sm">
            <li><a href="tel:07792663847" class="hover:text-white transition-colors">07792 663847</a></li>
            <li><a href="mailto:art@howlatthemoondogwalking.co.uk" class="hover:text-white transition-colors break-all">art@howlatthemoondogwalking.co.uk</a></li>
            <li class="text-white/40">10 Rectory Close, Ewhurst</li>
            <li class="text-white/40">Surrey GU6 7PU</li>
          </ul>
